# ============================================================================
# AI Reels Pipeline - environment variables
# Copy this file to `.env` and fill in your real values. Never commit `.env`.
# ============================================================================

# --- Google AI Studio (Nano Banana 2 / Gemini Image) ---
# Get a free key at https://aistudio.google.com/apikey
GOOGLE_AI_STUDIO_API_KEY=your_google_ai_studio_key_here
# Model identifier. Update if Google renames the image-gen model.
# Known names: gemini-2.5-flash-image (older, may still be free),
#              gemini-3.1-flash-image-preview (newer, paid),
#              gemini-3-flash-image, etc.
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview

# Optional: point the SDK at a custom Gemini-compatible endpoint (e.g. a
# proxy that handles auth differently — Antigravity, Vertex AI mirror,
# corporate gateway, etc.). Leave empty to hit Google directly.
# GOOGLE_AI_BASE_URL=https://my-proxy.example.com

# Optional: extra HTTP headers the proxy needs, as a JSON object string.
# Example: GOOGLE_AI_EXTRA_HEADERS={"X-Auth-Token":"xxx","X-Project":"yyy"}
# GOOGLE_AI_EXTRA_HEADERS={}

# --- ComfyUI (local or remote — only the HTTP port has to be reachable) ---
# Examples:
#   COMFYUI_HOST=http://127.0.0.1:8188      # ComfyUI on this machine
#   COMFYUI_HOST=http://192.168.1.42:8188   # ComfyUI on the LAN
#   COMFYUI_HOST=http://my-gpu-box:8188     # ComfyUI on a remote box
COMFYUI_HOST=http://127.0.0.1:8188
# Optional: client_id sent with prompts. Random UUID is fine.
COMFYUI_CLIENT_ID=ai-reels-pipeline

# --- Telegram notifications (see docs/TELEGRAM_SETUP.md) ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
# Set to 0 to silence all Telegram pings (still logs locally).
TELEGRAM_ENABLED=1

# --- Pipeline settings ---
# Path to SQLite state DB. Default: automation/db/state.db (relative to project root).
STATE_DB_PATH=db/state.db
# Where outputs land. Default: automation/outputs/
OUTPUTS_DIR=outputs
# Where guion JSONs live. Default: automation/guion/
GUION_DIR=guion
# Note: COMFYUI_INPUT_DIR and COMFYUI_OUTPUT_DIR are NO longer needed. The
# client uploads input images via POST /upload/image and downloads outputs
# via GET /view, so a shared filesystem is unnecessary. Only COMFYUI_HOST
# matters whether ComfyUI is local or remote.

# --- Watermark crop ---
# Pixels to crop from bottom of every Nano Banana 2 image before feeding to LTX.
# 80-120px works for current "Made with Google AI" tag. After crop the image
# is resized back to its original dimensions to preserve 9:16.
WATERMARK_CROP_PX=100

# --- Retry policy ---
IMAGE_MAX_ATTEMPTS=3
VIDEO_MAX_ATTEMPTS=2
# Seconds between poll cycles when watching the ComfyUI queue
POLL_INTERVAL_S=60
